---
import BaseLayout from '../layouts/BaseLayout.astro';

const lessons = [
  {
    id: 'piano',
    name: 'ピアノ',
    nameEn: 'Piano',
    ages: '4歳〜大人',
    description: 'クラシック・ポピュラーを問わず、基礎から丁寧に指導します。楽譜が読めない初心者の方も安心してスタートできます。バイエル・ソナチネから演奏会レベルの楽曲まで対応。',
    features: ['バイエルから演奏会レベルまで対応', 'グランドピアノ完備', 'コンクール対策サポート', '発表会年2回'],
    levels: ['入門・初級', '中級', '上級'],
    photo: 'https://images.pexels.com/photos/9391639/pexels-photo-9391639.jpeg?auto=compress&cs=tinysrgb&w=900&h=675&fit=crop',
    gradientClass: 'gradient-piano',
    accentColor: '#2c4a7c',
    accentLight: '#eef3fa',
    accentText: 'text-piano-500',
    accentBg: 'bg-piano-50 border-piano-100',
    accentBadge: 'bg-piano-100 text-piano-700',
    note: '♩',
    tagline: '感情の深さを鍵盤で表現する、音楽の王道',
  },
  {
    id: 'guitar',
    name: 'ギター',
    nameEn: 'Guitar',
    ages: '6歳〜大人',
    description: '音楽の入り口として人気のギター。アコースティック・クラシックギターを中心に、基礎から丁寧に指導します。弾き語りからソロギターまで、あなたのスタイルで楽しめます。',
    features: ['アコースティック・クラシックギター対応', 'コード・タブ譜から楽譜まで対応', '弾き語り・ソロギター両対応', '発表会・セッション機会あり'],
    levels: ['入門・初級', '中級', '上級'],
    photo: 'https://images.pexels.com/photos/8106076/pexels-photo-8106076.jpeg?auto=compress&cs=tinysrgb&w=900&h=675&fit=crop',
    gradientClass: 'gradient-guitar',
    accentColor: '#8b5e3c',
    accentLight: '#faf0e6',
    accentText: 'text-guitar-500',
    accentBg: 'bg-guitar-50 border-guitar-100',
    accentBadge: 'bg-guitar-100 text-guitar-700',
    note: '♪',
    tagline: '木の温もりが伝わる弦楽器の魅力',
  },
  {
    id: 'violin',
    name: 'バイオリン',
    nameEn: 'Violin',
    ages: '5歳〜大人',
    description: '弦楽器の王様・バイオリン。正しい姿勢・弓の使い方から丁寧に指導します。大人になってから始める方も多く在籍しています。子ども用の小さなサイズの楽器貸し出しも可能です。',
    features: ['小さなサイズの楽器貸し出しあり（子ども）', '音程・音色へのこだわり指導', 'アンサンブル参加機会あり', '発表会年2回'],
    levels: ['入門・初級', '中級', '上級'],
    photo: 'https://images.pexels.com/photos/7095052/pexels-photo-7095052.jpeg?auto=compress&cs=tinysrgb&w=900&h=675&fit=crop',
    gradientClass: 'gradient-violin',
    accentColor: '#7c2d4a',
    accentLight: '#faeef2',
    accentText: 'text-violin-500',
    accentBg: 'bg-violin-50 border-violin-100',
    accentBadge: 'bg-violin-100 text-violin-700',
    note: '♫',
    tagline: '魂を揺さぶる弦の響きを追い求めて',
  },
  {
    id: 'vocal',
    name: '声楽',
    nameEn: 'Vocal',
    ages: '小学生〜大人',
    description: '声は誰もが持つ楽器。正しい発声・呼吸法から、歌に込める表現まで幅広く指導します。クラシック・ポップス・ミュージカルなどジャンルも柔軟に対応。',
    features: ['発声・呼吸法の基礎から', 'クラシック・ポップス・ミュージカル対応', 'ステージパフォーマンス指導', '伴奏ピアノ付きレッスン'],
    levels: ['入門・初級', '中級', '上級・プロ志望'],
    photo: 'https://images.pexels.com/photos/8520514/pexels-photo-8520514.jpeg?auto=compress&cs=tinysrgb&w=900&h=675&fit=crop',
    gradientClass: 'gradient-vocal',
    accentColor: '#2a7f7a',
    accentLight: '#e8f4f3',
    accentText: 'text-vocal-500',
    accentBg: 'bg-vocal-50 border-vocal-100',
    accentBadge: 'bg-vocal-100 text-vocal-700',
    note: '♬',
    tagline: 'あなたの声が、最高の楽器になる',
  },
];
---

<BaseLayout
  title="レッスン内容"
  description="ピアノ・ギター・バイオリン・声楽など多彩なレッスンをご用意。初心者からプロ志望まで、個別指導で丁寧にサポートします。"
>

  <!-- ===== Page Header ===== -->
  <section class="relative py-28 bg-charcoal-900 overflow-hidden">
    <!-- Background texture + decorative -->
    <div
      class="absolute inset-0 opacity-[0.035]"
      style="background-image: repeating-linear-gradient(to bottom, transparent 0px, transparent 19px, rgba(255,255,255,1) 19px, rgba(255,255,255,1) 20px);"
      aria-hidden="true"
    />
    <div class="absolute right-0 top-0 w-1/2 h-full overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="font-serif text-[22rem] text-white opacity-[0.02] leading-none select-none -mt-12 ml-16">♫</div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-12 bg-gold-400" />
        <p class="text-gold-400 text-[10px] tracking-[0.28em] uppercase font-semibold">Our Lessons</p>
      </div>
      <h1 class="font-serif text-5xl sm:text-6xl text-cream-50 font-light mb-4">
        レッスン<em class="not-italic font-bold italic text-gold-400">内容</em>
      </h1>
      <p class="text-cream-200/70 text-sm max-w-lg leading-relaxed">
        初心者からプロ志望まで、あなたのペースと目標に合わせて丁寧にサポートします。
      </p>

      <!-- Course navigation pills -->
      <div class="flex flex-wrap gap-3 mt-8">
        {lessons.map(l => (
          <a
            href={`#${l.id}`}
            class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 text-cream-200 text-xs font-medium
                   rounded-full hover:bg-gold-500 hover:text-forest-900 transition-all duration-200 border border-white/10"
          >
            <span class="text-base">{l.note}</span>
            {l.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Lessons ===== -->
  <div class="divide-y divide-cream-200">
    {lessons.map((lesson, i) => (
      <article id={lesson.id} class="scroll-mt-20 fade-in" style={`transition-delay: ${i * 60}ms`}>
        <div class={`grid grid-cols-1 lg:grid-cols-2 ${i % 2 === 1 ? '' : ''}`}>

          <!-- Visual panel with course-specific color gradient + photo -->
          <div class={`relative overflow-hidden aspect-[4/3] lg:aspect-auto ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
            <img
              src={lesson.photo}
              alt={`${lesson.name}レッスン`}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <!-- Gradient overlay with course color -->
            <div class={`absolute inset-0 ${lesson.gradientClass} opacity-80`} />

            <!-- Course info overlay -->
            <div class="absolute inset-0 flex flex-col justify-end p-8 sm:p-12">
              <div class="font-serif text-5xl text-white opacity-20 mb-4 select-none">{lesson.note}</div>
              <p class="text-white/60 text-[10px] tracking-[0.28em] uppercase font-semibold mb-2">{lesson.nameEn}</p>
              <h2 class="font-serif text-4xl sm:text-5xl text-white font-light mb-3">
                {lesson.name}
              </h2>
              <p class="text-white/75 text-sm italic">{lesson.tagline}</p>
            </div>
          </div>

          <!-- Content panel -->
          <div class={`${lesson.accentBg} border-0 p-8 sm:p-12 lg:p-16 flex flex-col justify-center ${i % 2 === 1 ? 'lg:order-1' : ''}`}>

            <p class="text-xs font-medium tracking-wide text-charcoal-700/60 mb-6">
              対象年齢：<strong class="text-charcoal-900">{lesson.ages}</strong>
            </p>

            <p class="text-charcoal-700 leading-relaxed text-[15px] mb-8">{lesson.description}</p>

            <!-- Features -->
            <div class="mb-8">
              <h3 class={`text-[10px] font-semibold tracking-[0.2em] uppercase ${lesson.accentText} mb-4`}>
                コースの特徴
              </h3>
              <ul class="space-y-2.5">
                {lesson.features.map(f => (
                  <li class="flex items-start gap-3 text-sm text-charcoal-700">
                    <span class="mt-1 flex-shrink-0 text-base leading-none" style={`color: ${lesson.accentColor}`}>♩</span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Level badges -->
            <div class="mb-8">
              <h3 class={`text-[10px] font-semibold tracking-[0.2em] uppercase ${lesson.accentText} mb-4`}>
                対応レベル
              </h3>
              <div class="flex flex-wrap gap-2">
                {lesson.levels.map(l => (
                  <span class={`${lesson.accentBadge} px-3 py-1.5 text-xs font-medium rounded-full border border-current/20`}>
                    {l}
                  </span>
                ))}
              </div>
            </div>

            <a
              href="/trial"
              class="inline-flex items-center gap-2 px-6 py-3.5 text-white text-sm font-medium
                     hover:opacity-90 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg w-fit"
              style={`background-color: ${lesson.accentColor};`}
            >
              <span>{lesson.note}</span>
              {lesson.name}の体験レッスンを申し込む
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- ===== CTA ===== -->
  <section class="py-20 bg-cream-50 border-t border-cream-200">
    <div class="max-w-3xl mx-auto px-4 text-center fade-in">
      <p class="text-forest-700 text-[10px] tracking-[0.28em] uppercase font-semibold mb-4">Next Step</p>
      <h2 class="font-serif text-3xl sm:text-4xl text-charcoal-900 font-light mb-4">
        料金・スケジュールを<em class="not-italic font-bold italic text-forest-700">確認する</em>
      </h2>
      <p class="text-charcoal-700 text-sm mb-10">
        各コースの詳細料金や、レッスンスケジュールについてはこちらからご確認いただけます。
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/pricing"
           class="px-8 py-4 bg-forest-700 text-cream-50 text-sm font-medium hover:bg-forest-600 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg">
          料金プランを見る
        </a>
        <a href="/contact"
           class="px-8 py-4 border border-forest-700/60 text-forest-700 text-sm font-medium hover:bg-forest-700 hover:text-cream-50 transition-all duration-200">
          お問い合わせ
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
